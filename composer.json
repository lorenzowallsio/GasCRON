{
  "name": "antigravity/gas-connect-cron",
  "description": "Daily RSS feed transformer and publisher for Walls.io consumption.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "GasConnect\\RssCron\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GasConnect\\RssCron\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "generate-feed": "php bin/generate-transformed-rss.php",
    "test": "phpunit --configuration phpunit.xml.dist"
  }
}

